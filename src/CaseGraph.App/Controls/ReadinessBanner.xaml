<UserControl x:Class="CaseGraph.App.Controls.ReadinessBanner"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:CaseGraph.App.Services">
    <Border Padding="{StaticResource Space12}"
            CornerRadius="8"
            BorderThickness="1">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Visibility" Value="Collapsed" />
                <Setter Property="Background" Value="#FFF4F8FB" />
                <Setter Property="BorderBrush" Value="#FFB8CFDE" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding State.IsVisible, ElementName=Root}" Value="True">
                        <Setter Property="Visibility" Value="Visible" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding State.Tone, ElementName=Root}" Value="{x:Static controls:ReadinessBannerTone.Success}">
                        <Setter Property="Background" Value="#FFEFF8EC" />
                        <Setter Property="BorderBrush" Value="#FF9FC59A" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding State.Tone, ElementName=Root}" Value="{x:Static controls:ReadinessBannerTone.Error}">
                        <Setter Property="Background" Value="#FFFDEEEE" />
                        <Setter Property="BorderBrush" Value="#FFD7A1A1" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <StackPanel>
            <TextBlock FontWeight="SemiBold"
                       Text="{Binding State.Title, ElementName=Root}" />
            <TextBlock Margin="{StaticResource SpaceTop8}"
                       Text="{Binding State.Message, ElementName=Root}"
                       TextWrapping="Wrap" />
            <TextBlock Margin="{StaticResource SpaceTop8}"
                       FontStyle="Italic"
                       Text="Background work is running."
                       Visibility="Collapsed">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding State.IsBusy, ElementName=Root}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </StackPanel>
    </Border>
</UserControl>
