<UserControl x:Class="CaseGraph.App.Views.Pages.OrganizationProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource ContentBackgroundBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="{StaticResource Space16}">
            <Border Style="{StaticResource PlaceholderHintBorderStyle}">
                <StackPanel>
                    <DockPanel>
                        <Button DockPanel.Dock="Left"
                                Content="Back"
                                Command="{Binding NavigateBackCommand}"
                                Style="{StaticResource TopBarButtonStyle}" />
                        <StackPanel Margin="{StaticResource SpaceLeft12}">
                            <TextBlock Text="{Binding HeaderTitle}" Style="{StaticResource PageTitleTextStyle}" />
                            <TextBlock Margin="{StaticResource SpaceTop4}"
                                       Text="{Binding HeaderSubtitle}"
                                       Style="{StaticResource SecondaryBodyTextStyle}" />
                        </StackPanel>
                    </DockPanel>
                </StackPanel>
            </Border>

            <TextBlock Margin="{StaticResource SpaceTop12}"
                       Text="Record no longer available">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource BodyTextStyle}">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsRecordAvailable}" Value="False">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <StackPanel>
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsRecordAvailable}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>

                <Border Margin="{StaticResource SpaceTop12}" Style="{StaticResource PlaceholderHintBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Overview" Style="{StaticResource SectionTitleTextStyle}" />

                        <TextBlock Margin="{StaticResource SpaceTop12}" Text="Organization Name" Style="{StaticResource SecondaryBodyTextStyle}" />
                        <TextBlock Text="{Binding OrganizationName}" Style="{StaticResource BodyTextStyle}" />

                        <TextBlock Margin="{StaticResource SpaceTop8}" Text="Type" Style="{StaticResource SecondaryBodyTextStyle}" />
                        <TextBlock Text="{Binding OrganizationTypeDisplay}" Style="{StaticResource BodyTextStyle}" />

                        <TextBlock Margin="{StaticResource SpaceTop8}" Text="Status" Style="{StaticResource SecondaryBodyTextStyle}" />
                        <TextBlock Text="{Binding OrganizationStatusDisplay}" Style="{StaticResource BodyTextStyle}" />

                        <TextBlock Margin="{StaticResource SpaceTop8}" Text="Parent Organization" Style="{StaticResource SecondaryBodyTextStyle}" />
                        <TextBlock Text="{Binding ParentOrganizationDisplay}" Style="{StaticResource BodyTextStyle}" />

                        <TextBlock Margin="{StaticResource SpaceTop8}" Text="Summary / Notes" Style="{StaticResource SecondaryBodyTextStyle}" />
                        <TextBlock Text="{Binding SummaryDisplay}" TextWrapping="Wrap" Style="{StaticResource BodyTextStyle}" />

                        <TextBlock Margin="{StaticResource SpaceTop8}" Text="Created (UTC)" Style="{StaticResource SecondaryBodyTextStyle}" />
                        <TextBlock Text="{Binding CreatedAtUtc, StringFormat={}{0:u}, TargetNullValue=(none)}" Style="{StaticResource BodyTextStyle}" />

                        <TextBlock Margin="{StaticResource SpaceTop8}" Text="Updated (UTC)" Style="{StaticResource SecondaryBodyTextStyle}" />
                        <TextBlock Text="{Binding UpdatedAtUtc, StringFormat={}{0:u}, TargetNullValue=(none)}" Style="{StaticResource BodyTextStyle}" />
                    </StackPanel>
                </Border>

                <Border Margin="{StaticResource SpaceTop12}" Style="{StaticResource PlaceholderHintBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Aliases" Style="{StaticResource SectionTitleTextStyle}" />
                        <ListBox Margin="{StaticResource SpaceTop12}" ItemsSource="{Binding Aliases}">
                            <ListBox.Style>
                                <Style TargetType="ListBox">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasAliases}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.Style>
                        </ListBox>
                        <TextBlock Margin="{StaticResource SpaceTop12}"
                                   Text="{Binding AliasesEmptyState}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource SecondaryBodyTextStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasAliases}" Value="False">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border Margin="{StaticResource SpaceTop12}" Style="{StaticResource PlaceholderHintBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Memberships" Style="{StaticResource SectionTitleTextStyle}" />

                        <DataGrid Margin="{StaticResource SpaceTop12}"
                                  ItemsSource="{Binding Memberships}"
                                  SelectedItem="{Binding SelectedMembership, Mode=TwoWay}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  MouseDoubleClick="OnMembershipsDoubleClick">
                            <DataGrid.Style>
                                <Style TargetType="DataGrid">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasMemberships}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.Style>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Person" Binding="{Binding DisplayName}" Width="1.5*" />
                                <DataGridTextColumn Header="Membership" Binding="{Binding DetailText}" Width="2.4*" />
                                <DataGridTextColumn Header="Documentation" Binding="{Binding DocumentationDetailDisplay}" Width="2*" />
                                <DataGridTemplateColumn Header="Action" Width="1.2*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="{Binding ActionLabel}"
                                                    Command="{Binding DataContext.OpenMembershipPersonCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource TopBarButtonStyle}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock Margin="{StaticResource SpaceTop12}"
                                   Text="{Binding MembershipsEmptyState}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource SecondaryBodyTextStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasMemberships}" Value="False">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border Margin="{StaticResource SpaceTop12}" Style="{StaticResource PlaceholderHintBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Child Organizations" Style="{StaticResource SectionTitleTextStyle}" />
                        <ListBox Margin="{StaticResource SpaceTop12}"
                                 ItemsSource="{Binding Children}"
                                 MouseDoubleClick="OnChildrenDoubleClick">
                            <ListBox.Style>
                                <Style TargetType="ListBox">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasChildren}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.Style>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="0,8">
                                        <DockPanel>
                                            <Button DockPanel.Dock="Right"
                                                    Content="Open"
                                                    Command="{Binding DataContext.OpenChildOrganizationCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource TopBarButtonStyle}" />
                                            <StackPanel Margin="{StaticResource SpaceRight12}">
                                                <TextBlock Text="{Binding Name}" Style="{StaticResource BodyTextStyle}" />
                                                <TextBlock Margin="{StaticResource SpaceTop4}"
                                                           Text="{Binding Summary, TargetNullValue=(no summary)}"
                                                           TextWrapping="Wrap"
                                                           Style="{StaticResource SecondaryBodyTextStyle}" />
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <TextBlock Margin="{StaticResource SpaceTop12}"
                                   Text="{Binding ChildrenEmptyState}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource SecondaryBodyTextStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasChildren}" Value="False">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
