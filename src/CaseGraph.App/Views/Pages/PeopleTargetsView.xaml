<UserControl x:Class="CaseGraph.App.Views.Pages.PeopleTargetsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource ContentBackgroundBrush}">
    <Grid Margin="{StaticResource Space16}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0">
            <TextBlock DockPanel.Dock="Left"
                       Text="People / Targets"
                       Style="{StaticResource PageTitleTextStyle}" />
            <StackPanel DockPanel.Dock="Right">
                <TextBlock Text="Search Targets" Style="{StaticResource SecondaryBodyTextStyle}" />
                <StackPanel Margin="{StaticResource SpaceTop4}" Orientation="Horizontal">
                    <TextBox Width="260"
                             Margin="{StaticResource SpaceRight12}"
                             Text="{Binding TargetSearchQuery, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource TopBarTextBoxStyle}" />
                    <Button Content="Refresh"
                            Command="{Binding RefreshTargetsCommand}"
                            Style="{StaticResource TopBarButtonStyle}" />
                </StackPanel>
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="1" Margin="{StaticResource SpaceTop12}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PlaceholderHintBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Targets" Style="{StaticResource SectionTitleTextStyle}" />
                    <ListBox Grid.Row="1"
                             Margin="{StaticResource SpaceTop12}"
                             ItemsSource="{Binding Targets}"
                             SelectedItem="{Binding SelectedTargetSummary, Mode=TwoWay}"
                             MouseDoubleClick="OnTargetsDoubleClick">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="0,8">
                                    <DockPanel LastChildFill="True">
                                        <Button DockPanel.Dock="Right"
                                                Content="Open"
                                                Command="{Binding DataContext.OpenTargetProfileCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource TopBarButtonStyle}" />
                                        <StackPanel Margin="{StaticResource SpaceRight12}">
                                            <TextBlock Text="{Binding DisplayName}" Style="{StaticResource BodyTextStyle}" />
                                            <TextBlock Margin="{StaticResource SpaceTop4}"
                                                       Text="{Binding PrimaryAlias, TargetNullValue=(no alias)}"
                                                       Style="{StaticResource SecondaryBodyTextStyle}" />
                                            <TextBlock Margin="{StaticResource SpaceTop4}"
                                                       Text="{Binding AffiliationSummary}"
                                                       TextWrapping="Wrap"
                                                       Style="{StaticResource SecondaryBodyTextStyle}" />
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <TextBlock Grid.Row="1"
                               Margin="{StaticResource SpaceTop12}"
                               Text="No targets found">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource SecondaryBodyTextStyle}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Targets.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>

            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Style="{StaticResource PlaceholderHintBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Create New Target" Style="{StaticResource SectionTitleTextStyle}" />

                            <TextBlock Margin="{StaticResource SpaceTop12}"
                                       Style="{StaticResource SecondaryBodyTextStyle}"
                                       Text="Display Name" />
                            <TextBox Text="{Binding NewTargetDisplayName, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource TopBarTextBoxStyle}" />

                            <TextBlock Margin="{StaticResource SpaceTop8}"
                                       Style="{StaticResource SecondaryBodyTextStyle}"
                                       Text="Primary Alias" />
                            <TextBox Text="{Binding NewTargetPrimaryAlias, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource TopBarTextBoxStyle}" />

                            <TextBlock Margin="{StaticResource SpaceTop8}"
                                       Style="{StaticResource SecondaryBodyTextStyle}"
                                       Text="Notes" />
                            <TextBox Text="{Binding NewTargetNotes, UpdateSourceTrigger=PropertyChanged}"
                                     MinHeight="70"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     Style="{StaticResource TopBarTextBoxStyle}" />

                            <TextBlock Margin="{StaticResource SpaceTop8}"
                                       Style="{StaticResource SecondaryBodyTextStyle}"
                                       Text="Global Person (Optional)" />
                            <CheckBox Margin="{StaticResource SpaceTop8}"
                                      Content="Create and link a new global person"
                                      IsChecked="{Binding CreateTargetWithNewGlobalPerson, Mode=TwoWay}" />
                            <ComboBox Margin="{StaticResource SpaceTop8}"
                                      ItemsSource="{Binding GlobalPersonSearchResults}"
                                      SelectedItem="{Binding CreateTargetSelectedGlobalPerson, Mode=TwoWay}"
                                      DisplayMemberPath="DisplayName"
                                      Style="{StaticResource TopBarComboBoxStyle}" />

                            <Button Margin="{StaticResource SpaceTop12}"
                                    Content="Create Target"
                                    Command="{Binding CreateTargetCommand}"
                                    Style="{StaticResource TopBarButtonStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Margin="{StaticResource SpaceTop12}" Style="{StaticResource PlaceholderHintBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Selected Target" Style="{StaticResource SectionTitleTextStyle}" />

                            <TextBlock Margin="{StaticResource SpaceTop12}"
                                       Style="{StaticResource SecondaryBodyTextStyle}"
                                       Text="Display Name" />
                            <TextBox Text="{Binding SelectedTargetDisplayName, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource TopBarTextBoxStyle}" />

                            <TextBlock Margin="{StaticResource SpaceTop8}"
                                       Style="{StaticResource SecondaryBodyTextStyle}"
                                       Text="Primary Alias" />
                            <TextBox Text="{Binding SelectedTargetPrimaryAlias, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource TopBarTextBoxStyle}" />

                            <TextBlock Margin="{StaticResource SpaceTop8}"
                                       Style="{StaticResource SecondaryBodyTextStyle}"
                                       Text="Notes" />
                            <TextBox Text="{Binding SelectedTargetNotes, UpdateSourceTrigger=PropertyChanged}"
                                     MinHeight="70"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     Style="{StaticResource TopBarTextBoxStyle}" />

                            <Button Margin="{StaticResource SpaceTop12}"
                                    Content="Save Target"
                                    Command="{Binding SaveSelectedTargetCommand}"
                                    IsEnabled="{Binding HasSelectedTarget}"
                                    Style="{StaticResource TopBarButtonStyle}" />
                            <Button Margin="{StaticResource SpaceTop8}"
                                    Content="Open Profile"
                                    Command="{Binding OpenSelectedTargetProfileCommand}"
                                    IsEnabled="{Binding HasSelectedTarget}"
                                    Style="{StaticResource TopBarButtonStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Margin="{StaticResource SpaceTop12}" Style="{StaticResource PlaceholderHintBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Global Person" Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock Margin="{StaticResource SpaceTop8}"
                                       Style="{StaticResource BodyTextStyle}"
                                       Text="{Binding SelectedTargetGlobalPersonSummary}" />

                            <TextBlock Margin="{StaticResource SpaceTop8}"
                                       Text="Search Global Person"
                                       Style="{StaticResource SecondaryBodyTextStyle}" />
                            <Grid Margin="{StaticResource SpaceTop8}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{Binding GlobalPersonSearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource TopBarTextBoxStyle}" />
                                <Button Grid.Column="2"
                                        Content="Search"
                                        Command="{Binding SearchGlobalPersonsCommand}"
                                        Style="{StaticResource TopBarButtonStyle}" />
                            </Grid>

                            <ListBox Margin="{StaticResource SpaceTop8}"
                                     MinHeight="80"
                                     ItemsSource="{Binding GlobalPersonSearchResults}"
                                     SelectedItem="{Binding SelectedGlobalPersonSearchResult, Mode=TwoWay}"
                                     DisplayMemberPath="DisplayName" />

                            <WrapPanel Margin="{StaticResource SpaceTop8}">
                                <Button Content="Link to Selected Global Person"
                                        Command="{Binding LinkSelectedTargetToGlobalPersonCommand}"
                                        IsEnabled="{Binding HasSelectedGlobalPersonSearchResult}"
                                        Style="{StaticResource TopBarButtonStyle}" />
                                <Button Margin="{StaticResource SpaceLeft8}"
                                        Content="Create + Link New Global Person"
                                        Command="{Binding CreateAndLinkGlobalPersonForSelectedTargetCommand}"
                                        IsEnabled="{Binding HasSelectedTarget}"
                                        Style="{StaticResource TopBarButtonStyle}" />
                                <Button Margin="{StaticResource SpaceLeft8}"
                                        Content="Unlink Global Person"
                                        Command="{Binding UnlinkSelectedTargetFromGlobalPersonCommand}"
                                        IsEnabled="{Binding HasSelectedTargetGlobalPerson}"
                                        Style="{StaticResource TopBarButtonStyle}" />
                            </WrapPanel>

                            <TextBlock Margin="{StaticResource SpaceTop8}"
                                       Style="{StaticResource SecondaryBodyTextStyle}"
                                       Text="Global Identifiers" />
                            <TextBlock Margin="{StaticResource SpaceTop8}"
                                       Text="No identifiers recorded">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource SecondaryBodyTextStyle}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasSelectedTargetGlobalIdentifiers}" Value="False">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <DataGrid Margin="{StaticResource SpaceTop8}"
                                      MinHeight="110"
                                      ItemsSource="{Binding SelectedTargetGlobalIdentifiers}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      IsReadOnly="True"
                                      Visibility="{Binding HasSelectedTargetGlobalIdentifiers, Converter={StaticResource BoolToVisibilityConverter}}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="*" />
                                    <DataGridTextColumn Header="Display" Binding="{Binding ValueDisplay}" Width="1.8*" />
                                    <DataGridTextColumn Header="Normalized" Binding="{Binding ValueNormalized}" Width="1.8*" />
                                    <DataGridCheckBoxColumn Header="Primary" Binding="{Binding IsPrimary}" Width="Auto" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <TextBlock Margin="{StaticResource SpaceTop8}"
                                       Style="{StaticResource SecondaryBodyTextStyle}"
                                       Text="Other Cases Where Seen" />
                            <TextBlock Margin="{StaticResource SpaceTop8}"
                                       Text="No linked global case references recorded">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource SecondaryBodyTextStyle}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasSelectedTargetGlobalOtherCases}" Value="False">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <DataGrid Margin="{StaticResource SpaceTop8}"
                                      MinHeight="110"
                                      ItemsSource="{Binding SelectedTargetGlobalOtherCases}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      IsReadOnly="True"
                                      Visibility="{Binding HasSelectedTargetGlobalOtherCases, Converter={StaticResource BoolToVisibilityConverter}}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Case" Binding="{Binding CaseName}" Width="1.6*" />
                                    <DataGridTextColumn Header="Target" Binding="{Binding TargetDisplayName}" Width="1.6*" />
                                    <DataGridTextColumn Header="Case Id" Binding="{Binding CaseId}" Width="1.8*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>

                    <Border Margin="{StaticResource SpaceTop12}" Style="{StaticResource PlaceholderHintBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Aliases" Style="{StaticResource SectionTitleTextStyle}" />

                            <ListBox Margin="{StaticResource SpaceTop12}"
                                     MinHeight="90"
                                     ItemsSource="{Binding SelectedTargetAliases}"
                                     SelectedItem="{Binding SelectedTargetAlias, Mode=TwoWay}"
                                     DisplayMemberPath="Alias" />
                            <TextBlock Margin="{StaticResource SpaceTop8}"
                                       Text="No aliases recorded">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource SecondaryBodyTextStyle}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasSelectedTargetAliases}" Value="False">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <TextBlock Margin="{StaticResource SpaceTop8}"
                                       Text="New Alias"
                                       Style="{StaticResource SecondaryBodyTextStyle}" />
                            <TextBox Margin="{StaticResource SpaceTop8}"
                                     Text="{Binding NewAliasText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource TopBarTextBoxStyle}" />

                            <StackPanel Margin="{StaticResource SpaceTop8}" Orientation="Horizontal">
                                <Button Content="Add Alias"
                                        Command="{Binding AddAliasCommand}"
                                        IsEnabled="{Binding HasSelectedTarget}"
                                        Style="{StaticResource TopBarButtonStyle}" />
                                <Button Margin="{StaticResource SpaceLeft8}"
                                        Content="Remove Alias"
                                        Command="{Binding RemoveAliasCommand}"
                                        IsEnabled="{Binding HasSelectedTargetAlias}"
                                        Style="{StaticResource TopBarButtonStyle}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Margin="{StaticResource SpaceTop12}" Style="{StaticResource PlaceholderHintBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Identifiers" Style="{StaticResource SectionTitleTextStyle}" />

                            <DataGrid Margin="{StaticResource SpaceTop12}"
                                      MinHeight="150"
                                      ItemsSource="{Binding SelectedTargetIdentifiers}"
                                      SelectedItem="{Binding SelectedTargetIdentifier, Mode=TwoWay}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="*" />
                                    <DataGridTextColumn Header="Raw" Binding="{Binding ValueRaw}" Width="1.7*" />
                                    <DataGridTextColumn Header="Normalized" Binding="{Binding ValueNormalized}" Width="1.7*" />
                                    <DataGridCheckBoxColumn Header="Primary" Binding="{Binding IsPrimary}" Width="Auto" />
                                </DataGrid.Columns>
                            </DataGrid>
                            <TextBlock Margin="{StaticResource SpaceTop8}"
                                       Text="No identifiers recorded">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource SecondaryBodyTextStyle}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasSelectedTargetIdentifiers}" Value="False">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <Grid Margin="{StaticResource SpaceTop8}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Identifier Type" Style="{StaticResource SecondaryBodyTextStyle}" />
                                    <ComboBox Margin="{StaticResource SpaceTop8}"
                                              ItemsSource="{Binding AvailableIdentifierTypes}"
                                              SelectedItem="{Binding IdentifierEditorType, Mode=TwoWay}"
                                              Style="{StaticResource TopBarComboBoxStyle}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Identifier Value" Style="{StaticResource SecondaryBodyTextStyle}" />
                                    <TextBox Margin="{StaticResource SpaceTop8}"
                                             Text="{Binding IdentifierEditorValueRaw, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource TopBarTextBoxStyle}" />
                                </StackPanel>
                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="Notes" Style="{StaticResource SecondaryBodyTextStyle}" />
                                    <TextBox Margin="{StaticResource SpaceTop8}"
                                             Text="{Binding IdentifierEditorNotes, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource TopBarTextBoxStyle}" />
                                </StackPanel>
                            </Grid>

                            <CheckBox Margin="{StaticResource SpaceTop8}"
                                      Content="Primary identifier"
                                      IsChecked="{Binding IdentifierEditorIsPrimary, Mode=TwoWay}" />

                            <TextBlock Margin="{StaticResource SpaceTop8}"
                                       Text="{Binding IdentifierValueValidationMessage}"
                                       Visibility="{Binding ShowIdentifierValueValidationMessage, Converter={StaticResource BoolToVisibilityConverter}}"
                                       Style="{StaticResource SecondaryBodyTextStyle}" />

                            <StackPanel Margin="{StaticResource SpaceTop8}" Orientation="Horizontal">
                                <Button Content="Add Identifier"
                                        Command="{Binding AddIdentifierCommand}"
                                        IsEnabled="{Binding CanAddIdentifier}"
                                        Style="{StaticResource TopBarButtonStyle}" />
                                <Button Margin="{StaticResource SpaceLeft8}"
                                        Content="Update Identifier"
                                        Command="{Binding UpdateIdentifierCommand}"
                                        IsEnabled="{Binding HasSelectedTargetIdentifier}"
                                        Style="{StaticResource TopBarButtonStyle}" />
                                <Button Margin="{StaticResource SpaceLeft8}"
                                        Content="Remove Identifier"
                                        Command="{Binding RemoveIdentifierCommand}"
                                        IsEnabled="{Binding HasSelectedTargetIdentifier}"
                                        Style="{StaticResource TopBarButtonStyle}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Margin="{StaticResource SpaceTop12}" Style="{StaticResource PlaceholderHintBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Where Seen (Messages)" Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock Margin="{StaticResource SpaceTop8}"
                                       Style="{StaticResource BodyTextStyle}"
                                       Text="{Binding SelectedTargetWhereSeenSummary}" />
                            <Button Margin="{StaticResource SpaceTop8}"
                                    Content="Search messages for this Target"
                                    Command="{Binding OpenSearchForSelectedTargetCommand}"
                                    IsEnabled="{Binding HasSelectedTarget}"
                                    Style="{StaticResource TopBarButtonStyle}" />
                            <TextBlock Margin="{StaticResource SpaceTop8}"
                                       Text="No identifiers recorded">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource SecondaryBodyTextStyle}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasSelectedTargetWhereSeenIdentifiers}" Value="False">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <DataGrid Margin="{StaticResource SpaceTop8}"
                                      MinHeight="140"
                                      ItemsSource="{Binding SelectedTargetWhereSeenIdentifiers}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      Visibility="{Binding HasSelectedTargetWhereSeenIdentifiers, Converter={StaticResource BoolToVisibilityConverter}}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="*" />
                                    <DataGridTextColumn Header="Identifier" Binding="{Binding ValueDisplay}" Width="1.8*" />
                                    <DataGridTextColumn Header="Count" Binding="{Binding Count}" Width="0.8*" />
                                    <DataGridTextColumn Header="Last Seen (UTC)"
                                                        Binding="{Binding LastSeenUtc, StringFormat={}{0:u}, TargetNullValue=(none)}"
                                                        Width="1.4*" />
                                    <DataGridTemplateColumn Header="Actions" Width="1.4*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="Search for Identifier"
                                                        Command="{Binding DataContext.OpenSearchForIdentifierCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource TopBarButtonStyle}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
